{
  "name": "nancy-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "tsc -p tsconfig.json",
    "migrate": "bun src/db/migrate.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test tests/*.test.ts",
    "telegram:setup": "bun src/qa/configureTelegramBot.ts",
    "acceptance:static": "bun src/qa/staticAcceptance.ts",
    "acceptance:live": "bun src/qa/liveAcceptance.ts",
    "sim:full": "bun src/qa/fullSimulation.ts",
    "smoke:local": "bun src/qa/localSmoke.ts",
    "smoke:live": "bun src/qa/liveSmoke.ts",
    "verify": "bun run typecheck && bun run test && bun run acceptance:static",
    "verify:full": "bun run verify && bun run build && bun run sim:full && bun run smoke:local && bun run acceptance:live && bun run smoke:live"
  },
  "dependencies": {
    "grammy": "^1.34.0",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "viem": "^2.23.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.11",
    "typescript": "^5.7.2"
  },
  "engines": {
    "bun": ">=1.3.13"
  },
  "module": "src/index.ts"
}
