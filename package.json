{
  "name": "the-family-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "tsc -p tsconfig.json",
    "migrate": "bun src/db/migrate.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test tests/*.test.ts",
    "acceptance:static": "bun src/qa/staticAcceptance.ts",
    "acceptance:live": "bun src/qa/liveAcceptance.ts",
    "verify": "bun run typecheck && bun run test && bun run acceptance:static"
  },
  "dependencies": {
    "grammy": "^1.34.0",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "viem": "^2.23.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.11",
    "typescript": "^5.7.2"
  },
  "engines": {
    "bun": ">=1.3.13"
  },
  "module": "src/index.ts"
}
